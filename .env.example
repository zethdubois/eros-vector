# Product copy/flow mode. Set false to restore public-release behavior.
PUBLIC_BETA_MODE=true

# Shared invite passwords (server-only — never commit real values)
ACCESS_PASSWORD_BETA='your public access password'
ACCESS_PASSWORD_REVIEWER=change-me-reviewer
ACCESS_PASSWORD_DEVELOPER=change-me-developer

# Long random string used to sign the access cookie (HMAC)
ACCESS_COOKIE_SECRET=generate-a-long-random-string-here

# Salt for hashing visitor IPs (raw IPs are never stored). Falls back to ACCESS_COOKIE_SECRET if unset.
IP_HASH_SECRET=generate-another-long-random-string-here

# PostgreSQL — Railway app service should use the private URL (no egress fees).
DATABASE_URL=postgresql://user:password@postgres.railway.internal:5432/railway

# Optional: Railway public proxy URL for local `pnpm dev` / db scripts from your laptop.
# postgres.railway.internal does not resolve outside Railway.
# DATABASE_PUBLIC_URL=postgresql://user:password@HOST.proxy.rlwy.net:PORT/railway
