{
	"name": "eros-vector",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"packageManager": "pnpm@10.33.0",
	"scripts": {
		"dev": "vite dev --port 3000 --strictPort",
		"build": "vite build",
		"preview": "vite preview --port 3000 --strictPort",
		"start": "node build",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "tsx scripts/migrate.ts",
		"db:migrate:prod": "tsx scripts/migrate.ts --production",
		"db:seed": "tsx scripts/seed-survey-questions.ts",
		"db:seed:prod": "tsx scripts/seed-survey-questions.ts --production"
	},
	"devDependencies": {
		"@sveltejs/adapter-node": "^5.5.7",
		"@sveltejs/kit": "^2.63.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@types/node": "^26.1.1",
		"@types/pg": "^8.20.0",
		"dotenv": "^17.4.2",
		"drizzle-kit": "^0.31.10",
		"svelte": "^5.56.1",
		"svelte-check": "^4.6.0",
		"typescript": "^6.0.3",
		"vite": "^8.0.16"
	},
	"dependencies": {
		"drizzle-orm": "^0.45.2",
		"marked": "^18.0.6",
		"pg": "^8.22.0",
		"tsx": "^4.23.1"
	}
}
